{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["**/.env.*local", ".env"],
  "globalEnv": [
    "GITHUB_TOKEN",
    "EXA_API_KEY",
    "MINIMAX_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".eve/**", ".vercel/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    }
  }
}
