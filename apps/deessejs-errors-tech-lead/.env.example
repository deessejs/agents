# Phase 1 required
MINIMAX_API_KEY=

# Memory (phase 9) — Neon Postgres URL, shared with other ds-team agents
DATABASE_URL=

# MCP connections (added in this phase)
# GitHub: fine-grained PAT restricted to deessejs/errors,
#   `issues:write` + `pull_requests:write` only (NO `contents:write`).
#   https://github.com/settings/tokens
GITHUB_TOKEN=

# Exa: web search mandated by deessejs/errors/CLAUDE.md.
#   https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Later phases — declared for documentation, unused until their phase lands.
# Telegram channel (phase 5):
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Telegram whitelist — single-user gate on incoming bot messages.
# Also used by agent/schedules/daily-digest.ts as the target chat_id for
# the proactive Telegram send. To find your id, message @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_ID=
#
# Memory (phase 9):
# DATABASE_URL=
# OPENROUTER_API_KEY=