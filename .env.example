# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# Vercel Connect / AI Gateway — required for Vercel-hosted agents
MINIMAX_API_KEY=

# Exa — web search MCP (https://dashboard.exa.ai/api-keys)
EXA_API_KEY=

# GitHub — repos / issues / PRs MCP (https://github.com/settings/tokens)
# Required scopes depend on what your agent does.
GITHUB_TOKEN=
